# Portfolio Contact Form Notification Variables
# ---------------------------------------------
# Instructions:
# 1. Rename this file to ".env.local"
# 2. Fill in the values below with your actual API keys and credentials
# 3. Restart your Next.js development server (npm run dev)

# Email Integration (Nodemailer)
# ---------------------------------------------
# Use an App Password if using Gmail. Do not use your actual Google password.
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# The email address where you want to receive notifications (can be the same as EMAIL_USER)
MY_EMAIL_ADDRESS=your_email@gmail.com


# Twilio Integration (SMS & WhatsApp)
# ---------------------------------------------
# Sign up at twilio.com to get these credentials
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Your Twilio phone number (must be active for SMS and WhatsApp if using Sandbox)
TWILIO_PHONE_NUMBER=+1234567890

# The Twilio WhatsApp number (default is the Sandbox number, keep it unless you have a real one)
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Your personal phone number to receive the alerts (must include country code, e.g., +91...)
# If using Twilio Sandbox, you MUST join the sandbox from this number first!
MY_PHONE_NUMBER=+919876543210
